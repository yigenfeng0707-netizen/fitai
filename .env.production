# FitAI Production Environment Variables

# Database Configuration
POSTGRES_DB=fitai
POSTGRES_USER=fitai
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# Redis Configuration
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Security Configuration
SECRET_KEY=CHANGE_ME_GENERATE_WITH_python -c "from secrets import token_urlsafe(32); print(token_urlsafe(32))"

# AI Service Configuration
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Logging
LOG_LEVEL=INFO
