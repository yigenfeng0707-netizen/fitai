# === FitAI Production Environment ===
# Database
DB_NAME=fitai
DB_USER=fitai
DB_PASSWORD=CHANGE_ME_USE_LONG_RANDOM_STRING
DATABASE_URL=postgresql+asyncpg://fitai:CHANGE_ME@postgres:5432/fitai

# Redis
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# Security
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
ENVIRONMENT=production

# CORS
CORS_ORIGINS=https://app.fitai.com,https://admin.fitai.com

# WeChat (configure for production)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MCH_ID=
WECHAT_API_KEY=

# SMS (optional)
SMS_ENABLED=false
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_REQUEST_ENABLED=true
SLOW_REQUEST_THRESHOLD=5.0

# Database Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
