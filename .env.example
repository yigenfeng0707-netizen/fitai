# 应用
APP_NAME=健身瑜伽教培管理系统
APP_ENV=development
DEBUG=true

# 服务器
HOST=0.0.0.0
PORT=8000

# 数据库
DATABASE_URL=postgresql://fituser:fitpass123@postgres:5432/fit_saas
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# 密码
PASSWORD_SECRET_KEY=your-password-secret-key-change-in-production

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# AI (可选，Phase 2 启用)
AI_PROVIDER=
AI_API_KEY=